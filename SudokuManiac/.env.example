# Drizzle
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
# GitHub OAuth
# https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
# Google OAuth
# https://www.better-auth.com/docs/authentication/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# ─── AI provider (hints, crossword/alias word generation) ──────────────────────
# Pick the provider used by src/lib/server/ai/provider.ts. Default: openai.
#   AI_PROVIDER = openai | google | groq | mistral | anthropic
#   AI_MODEL    = optional model-id override
AI_PROVIDER="google"
# AI_MODEL="gemini-2.0-flash"

# Free tiers (no card needed to start):
#   Gemini  → https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=""
#   Groq    → https://console.groq.com/keys
GROQ_API_KEY=""
#   Mistral → https://console.mistral.ai/api-keys
MISTRAL_API_KEY=""

# Paid (optional):
# OpenAI  → https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Anthropic (install @ai-sdk/anthropic first) → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
