{
	"name": "sudokumaniac",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"db:start": "docker compose up",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.22",
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource/fira-mono": "^5.2.7",
		"@inlang/paraglide-js": "^2.20.1",
		"@neoconfetti/svelte": "^2.2.2",
		"@playwright/test": "^1.61.0",
		"@storybook/addon-a11y": "^10.4.6",
		"@storybook/addon-docs": "^10.4.6",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.6",
		"@storybook/sveltekit": "^10.4.6",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/kit": "^2.67.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@types/bun": "^1.3.14",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.9",
		"@vitest/coverage-v8": "^4.1.9",
		"better-auth": "^1.6.20",
		"daisyui": "^5.5.23",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.4.6",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.7.0",
		"playwright": "^1.61.0",
		"postgres": "^3.4.9",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"storybook": "^10.4.6",
		"svelte": "^5.56.3",
		"svelte-check": "^4.7.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.0",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@ai-sdk/openai": "^3.0.74",
		"ai": "^6.0.209",
		"approve-builds": "^1.0.0",
		"pixi.js": "^8.19.0",
		"zod": "^4.4.3"
	}
}
